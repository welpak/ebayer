<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            noupdate="1" ensures that once installed these records are not
            overwritten on subsequent module upgrades, which would reset
            user-configured intervals back to the defaults.

            All crons are inactive by default.  The res.config.settings
            set_values() method activates / deactivates each one when the
            user saves the Settings form.
        -->

        <!-- ============================================================
             Cron 1 — Fetch Orders from eBay
        ============================================================ -->
        <record id="ir_cron_fetch_orders" model="ir.cron">
            <field name="name">eBay: Fetch Orders</field>
            <field name="model_id" ref="model_ebay_instance"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_fetch_orders()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="nextcall"
                   eval="(DateTime.now() + timedelta(minutes=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">5</field>
        </record>

        <!-- ============================================================
             Cron 2 — Sync Inventory to eBay
        ============================================================ -->
        <record id="ir_cron_sync_inventory" model="ir.cron">
            <field name="name">eBay: Sync Inventory</field>
            <field name="model_id" ref="model_ebay_instance"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_sync_inventory()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="nextcall"
                   eval="(DateTime.now() + timedelta(minutes=35)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">10</field>
        </record>

        <!-- ============================================================
             Cron 3 — Pull Listings from eBay (eBay → Odoo)
        ============================================================ -->
        <record id="ir_cron_pull_listings" model="ir.cron">
            <field name="name">eBay: Pull Listings</field>
            <field name="model_id" ref="model_ebay_instance"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_pull_listings()</field>
            <field name="interval_number">60</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="nextcall"
                   eval="(DateTime.now() + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">15</field>
        </record>

        <!-- ============================================================
             Cron 4 — Export Orders to eBay (Odoo → eBay)
        ============================================================ -->
        <record id="ir_cron_export_orders" model="ir.cron">
            <field name="name">eBay: Export Orders</field>
            <field name="model_id" ref="model_ebay_instance"/>
            <field name="state">code</field>
            <field name="code">model.sudo()._cron_export_orders()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="nextcall"
                   eval="(DateTime.now() + timedelta(minutes=40)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">20</field>
        </record>

    </data>
</odoo>
