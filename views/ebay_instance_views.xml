<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             LIST VIEW
        ============================================================ -->
        <record id="view_ebay_instance_tree" model="ir.ui.view">
            <field name="name">ebay.instance.tree</field>
            <field name="model">ebay.instance</field>
            <field name="arch" type="xml">
                <tree string="eBay Instances"
                      decoration-muted="active == False">
                    <field name="name"/>
                    <field name="environment"
                           decoration-info="environment == 'sandbox'"
                           decoration-success="environment == 'production'"/>
                    <field name="app_id"/>
                    <field name="connection_status"
                           widget="badge"
                           decoration-success="connection_status == 'connected'"
                           decoration-danger="connection_status == 'error'"
                           decoration-muted="connection_status == 'not_connected'"/>
                    <field name="last_order_sync" string="Last Order Sync" optional="show"/>
                    <field name="enable_batch_sync" string="Batch Sync"/>
                    <field name="enable_instant_sync" string="Instant Sync"/>
                    <field name="token_expires_at" string="Token Expires" optional="show"/>
                    <field name="active" invisible="1"/>
                </tree>
            </field>
        </record>

        <!-- ============================================================
             FORM VIEW
        ============================================================ -->
        <record id="view_ebay_instance_form" model="ir.ui.view">
            <field name="name">ebay.instance.form</field>
            <field name="model">ebay.instance</field>
            <field name="arch" type="xml">
                <form string="eBay Instance">
                    <header>
                        <button name="action_test_connection"
                                string="Test Connection"
                                type="object"
                                class="oe_highlight"
                                attrs="{'invisible': [('connection_status', '=', 'connected')]}"/>
                        <button name="action_test_connection"
                                string="Re-test Connection"
                                type="object"
                                attrs="{'invisible': [('connection_status', '!=', 'connected')]}"/>
                        <field name="connection_status"
                               widget="statusbar"
                               statusbar_visible="not_connected,connected"/>
                    </header>
                    <sheet>
                        <!-- Smart-button bar -->
                        <div class="oe_button_box" name="button_box"/>

                        <!-- Archived ribbon -->
                        <widget name="web_ribbon"
                                title="Archived"
                                bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>

                        <!-- Title -->
                        <div class="oe_title">
                            <label for="name" string="Instance Name"/>
                            <h1>
                                <field name="name"
                                       placeholder="e.g. My eBay Shop — Production"/>
                            </h1>
                        </div>

                        <!-- Top-level settings -->
                        <group>
                            <group string="General">
                                <field name="environment"/>
                                <field name="company_id"
                                       groups="base.group_multi_company"/>
                                <field name="warehouse_id"/>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                            <group string="Synchronisation">
                                <field name="enable_instant_sync"
                                       widget="boolean_toggle"/>
                                <field name="enable_batch_sync"
                                       widget="boolean_toggle"/>
                                <field name="enable_listing_sync"
                                       widget="boolean_toggle"/>
                                <field name="enable_order_export"
                                       widget="boolean_toggle"/>
                                <field name="last_order_sync" readonly="1"/>
                                <field name="last_listing_pull_sync" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- Page 1: Application Keys + OAuth Tokens -->
                            <page string="API Credentials" name="credentials">
                                <group>
                                    <group string="Application Keys">
                                        <field name="app_id"
                                               placeholder="YOURNAME-XXXX-XXXX-XXXX"/>
                                        <field name="dev_id"
                                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
                                        <field name="cert_id"
                                               password="True"
                                               placeholder="••••••••••••"/>
                                    </group>
                                    <group string="OAuth 2.0 Tokens">
                                        <field name="access_token"
                                               password="True"
                                               placeholder="Populated after authorization"/>
                                        <field name="refresh_token"
                                               password="True"
                                               placeholder="Populated after authorization"/>
                                        <field name="token_expires_at"/>
                                        <field name="is_token_expired"
                                               readonly="1"
                                               attrs="{'invisible': [('access_token', 'in', [False, ''])]}"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Page 2: Listing Defaults -->
                            <page string="Listing Defaults" name="listing_defaults">
                                <group>
                                    <group string="Marketplace &amp; Policies">
                                        <field name="country_code"
                                               placeholder="e.g. US, GB, DE, AU"
                                               help="Two-letter ISO country code for the seller location. Used to create the eBay merchant location required when publishing listings."/>
                                        <field name="default_marketplace_id"
                                               placeholder="e.g. EBAY_US"/>
                                        <field name="default_fulfillment_policy_id"
                                               placeholder="Policy ID from Seller Hub"/>
                                        <field name="default_payment_policy_id"
                                               placeholder="Policy ID from Seller Hub"/>
                                        <field name="default_return_policy_id"
                                               placeholder="Policy ID from Seller Hub"/>
                                    </group>
                                    <group string="About Listing Defaults">
                                        <div class="o_field_widget">
                                            <p class="text-muted">
                                                These values are used as fallbacks when a
                                                product mapping does not specify its own
                                                marketplace or policy IDs.
                                            </p>
                                            <p class="text-muted">
                                                Find your policy IDs in
                                                <strong>eBay Seller Hub → Account → Policies</strong>.
                                            </p>
                                        </div>
                                    </group>
                                </group>
                            </page>

                            <!-- Page 3: Webhook Configuration -->
                            <page string="Webhook" name="webhook"
                                  attrs="{'invisible': [('enable_instant_sync', '=', False)]}">
                                <group>
                                    <group string="Endpoint Verification">
                                        <field name="webhook_verification_token"
                                               placeholder="Token copied from eBay Developer Portal → Notifications"/>
                                    </group>
                                    <group string="Webhook URL">
                                        <div class="o_field_widget">
                                            <p class="text-muted">
                                                Register the following URL as your eBay
                                                notification endpoint:
                                            </p>
                                            <code>/ebay/webhook/event</code>
                                            <p class="text-muted mt8">
                                                eBay will send a GET challenge to verify
                                                ownership before delivering events.
                                            </p>
                                        </div>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================
             SEARCH VIEW
        ============================================================ -->
        <record id="view_ebay_instance_search" model="ir.ui.view">
            <field name="name">ebay.instance.search</field>
            <field name="model">ebay.instance</field>
            <field name="arch" type="xml">
                <search string="Search eBay Instances">
                    <field name="name" string="Instance Name"/>
                    <field name="app_id" string="App ID"/>
                    <separator/>
                    <filter name="filter_connected"
                            string="Connected"
                            domain="[('connection_status', '=', 'connected')]"/>
                    <filter name="filter_sandbox"
                            string="Sandbox"
                            domain="[('environment', '=', 'sandbox')]"/>
                    <filter name="filter_production"
                            string="Production"
                            domain="[('environment', '=', 'production')]"/>
                    <separator/>
                    <filter name="filter_active"
                            string="Active"
                            domain="[('active', '=', True)]"/>
                    <filter name="filter_archived"
                            string="Archived"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_environment"
                                string="Environment"
                                context="{'group_by': 'environment'}"/>
                        <filter name="group_connection"
                                string="Connection Status"
                                context="{'group_by': 'connection_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             WINDOW ACTION
        ============================================================ -->
        <record id="action_ebay_instance" model="ir.actions.act_window">
            <field name="name">eBay Instances</field>
            <field name="res_model">ebay.instance</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_filter_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first eBay instance
                </p>
                <p>
                    Add your eBay Developer application credentials here.
                    Each record represents one eBay seller account.
                </p>
            </field>
        </record>

    </data>
</odoo>
