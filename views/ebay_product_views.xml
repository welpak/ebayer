<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             LIST VIEW
        ============================================================ -->
        <record id="view_ebay_product_mapping_tree" model="ir.ui.view">
            <field name="name">ebay.product.mapping.tree</field>
            <field name="model">ebay.product.mapping</field>
            <field name="arch" type="xml">
                <tree string="eBay Product Mappings"
                      decoration-muted="active == False or listing_status == 'ended'"
                      decoration-warning="listing_status == 'out_of_stock'"
                      decoration-success="listing_status == 'active' and sync_inventory == True">
                    <field name="ebay_item_id"    string="eBay Item ID"/>
                    <field name="instance_id"     string="Instance"/>
                    <field name="odoo_product_id" string="Odoo Product"/>
                    <field name="ebay_sku"         string="eBay SKU"/>
                    <field name="marketplace_id"   string="Marketplace" optional="show"/>
                    <field name="ebay_price"       string="Price" optional="show"/>
                    <field name="ebay_currency_id" string="Currency" invisible="1"/>
                    <field name="ebay_quantity"    string="eBay Qty"/>
                    <field name="listing_status"
                           widget="badge"
                           decoration-success="listing_status == 'active'"
                           decoration-danger="listing_status == 'ended'"
                           decoration-warning="listing_status == 'out_of_stock'"
                           decoration-muted="listing_status == 'unknown'"/>
                    <field name="sync_inventory"
                           string="Sync Stock"
                           widget="boolean_toggle"/>
                    <field name="last_listing_sync"    string="Last Listing Sync" optional="show"/>
                    <field name="last_inventory_sync"  string="Last Inventory Sync" optional="show"/>
                    <field name="active" invisible="1"/>
                </tree>
            </field>
        </record>

        <!-- ============================================================
             FORM VIEW
        ============================================================ -->
        <record id="view_ebay_product_mapping_form" model="ir.ui.view">
            <field name="name">ebay.product.mapping.form</field>
            <field name="model">ebay.product.mapping</field>
            <field name="arch" type="xml">
                <form string="eBay Product Mapping">
                    <header>
                        <!-- Publish: creates/updates inventory item + offer, then publishes -->
                        <button name="action_publish_to_ebay"
                                string="Publish to eBay"
                                type="object"
                                class="oe_highlight"
                                attrs="{'invisible': [('listing_status', '=', 'active')]}"/>
                        <!-- Update: re-push price/title/qty to a live listing -->
                        <button name="action_update_ebay_listing"
                                string="Update Listing"
                                type="object"
                                attrs="{'invisible': [('listing_status', '!=', 'active')]}"/>
                        <!-- Withdraw: end the listing without deleting the mapping -->
                        <button name="action_withdraw_from_ebay"
                                string="Withdraw from eBay"
                                type="object"
                                attrs="{'invisible': [('offer_id', 'in', [False, ''])]}"/>
                        <!-- Pull: fetch current eBay state into this record -->
                        <button name="action_pull_from_ebay"
                                string="Pull from eBay"
                                type="object"/>
                        <field name="listing_status"
                               widget="statusbar"
                               statusbar_visible="unknown,active,out_of_stock,ended"/>
                    </header>
                    <sheet>
                        <!-- Smart-button bar -->
                        <div class="oe_button_box" name="button_box"/>

                        <!-- Archived ribbon -->
                        <widget name="web_ribbon"
                                title="Archived"
                                bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>

                        <!-- Title -->
                        <div class="oe_title">
                            <label for="ebay_item_id" string="eBay Item ID"/>
                            <h1>
                                <field name="ebay_item_id"
                                       placeholder="e.g. 123456789012"
                                       readonly="1"/>
                            </h1>
                        </div>

                        <!-- Core mapping fields -->
                        <group>
                            <group string="Mapping">
                                <field name="instance_id"/>
                                <field name="odoo_product_id"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="odoo_product_tmpl_id"
                                       readonly="1"
                                       string="Product Template"/>
                                <field name="ebay_sku"/>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                            <group string="eBay Listing Status">
                                <field name="listing_status"
                                       widget="badge"
                                       decoration-success="listing_status == 'active'"
                                       decoration-danger="listing_status == 'ended'"
                                       decoration-warning="listing_status == 'out_of_stock'"
                                       decoration-muted="listing_status == 'unknown'"/>
                                <field name="offer_id" readonly="1"/>
                                <field name="ebay_quantity"/>
                                <field name="last_listing_sync" readonly="1"/>
                            </group>
                        </group>

                        <notebook>

                            <!-- ==========================================
                                 Page 1: Listing Details
                            =========================================== -->
                            <page string="Listing Details" name="listing_details">
                                <group>
                                    <group string="Content">
                                        <field name="ebay_title"
                                               placeholder="Max 80 characters"/>
                                        <field name="ebay_condition"/>
                                        <field name="ebay_category_id"
                                               placeholder="e.g. 9394"/>
                                        <field name="marketplace_id"/>
                                    </group>
                                    <group string="Pricing">
                                        <field name="ebay_price"/>
                                        <field name="ebay_currency_id"
                                               options="{'no_create': True}"/>
                                    </group>
                                </group>
                                <group string="Description">
                                    <field name="ebay_description"
                                           nolabel="1"
                                           placeholder="Listing description (HTML accepted)"/>
                                </group>
                                <group string="Business Policies">
                                    <group>
                                        <field name="fulfillment_policy_id"
                                               placeholder="Leave blank to use instance default"/>
                                        <field name="payment_policy_id"
                                               placeholder="Leave blank to use instance default"/>
                                        <field name="return_policy_id"
                                               placeholder="Leave blank to use instance default"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ==========================================
                                 Page 2: Inventory Sync
                            =========================================== -->
                            <page string="Inventory Sync" name="inventory_sync">
                                <group>
                                    <group>
                                        <field name="sync_inventory"
                                               widget="boolean_toggle"/>
                                        <field name="last_inventory_sync" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="sync_error_message"
                                               readonly="1"
                                               widget="text"
                                               attrs="{'invisible': [('sync_error_message', 'in', [False, ''])]}"/>
                                    </group>
                                </group>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================
             SEARCH VIEW
        ============================================================ -->
        <record id="view_ebay_product_mapping_search" model="ir.ui.view">
            <field name="name">ebay.product.mapping.search</field>
            <field name="model">ebay.product.mapping</field>
            <field name="arch" type="xml">
                <search string="Search Product Mappings">
                    <field name="ebay_item_id"    string="eBay Item ID"/>
                    <field name="ebay_sku"         string="eBay SKU"/>
                    <field name="ebay_title"       string="eBay Title"/>
                    <field name="odoo_product_id"  string="Odoo Product"/>
                    <field name="instance_id"      string="Instance"/>
                    <separator/>
                    <filter name="filter_active_listing"
                            string="Active Listings"
                            domain="[('listing_status', '=', 'active')]"/>
                    <filter name="filter_out_of_stock"
                            string="Out of Stock"
                            domain="[('listing_status', '=', 'out_of_stock')]"/>
                    <filter name="filter_ended"
                            string="Ended Listings"
                            domain="[('listing_status', '=', 'ended')]"/>
                    <separator/>
                    <filter name="filter_sync_inventory"
                            string="Inventory Sync On"
                            domain="[('sync_inventory', '=', True)]"/>
                    <filter name="filter_no_sync"
                            string="Inventory Sync Off"
                            domain="[('sync_inventory', '=', False)]"/>
                    <separator/>
                    <filter name="filter_archived"
                            string="Archived"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_instance"
                                string="Instance"
                                context="{'group_by': 'instance_id'}"/>
                        <filter name="group_listing_status"
                                string="Listing Status"
                                context="{'group_by': 'listing_status'}"/>
                        <filter name="group_marketplace"
                                string="Marketplace"
                                context="{'group_by': 'marketplace_id'}"/>
                        <filter name="group_product_template"
                                string="Product"
                                context="{'group_by': 'odoo_product_tmpl_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             WINDOW ACTION
        ============================================================ -->
        <record id="action_ebay_product_mapping" model="ir.actions.act_window">
            <field name="name">eBay Product Mappings</field>
            <field name="res_model">ebay.product.mapping</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_filter_active_listing': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No product mappings yet
                </p>
                <p>
                    Create a mapping to link an Odoo product to an eBay listing.
                    Use <strong>Publish to eBay</strong> to push new listings,
                    or enable <strong>Listing Sync</strong> to pull existing
                    eBay listings automatically.
                </p>
            </field>
        </record>

    </data>
</odoo>
