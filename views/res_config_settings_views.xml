<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Inherit the main Odoo Settings form and inject the eBay block.
            Odoo 16 uses the app_settings_block / data-key pattern to
            make each module's section appear as a separate "app" tab in
            the sidebar.
        -->
        <record id="res_config_settings_view_form_ebay_connector"
                model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.ebay_connector</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block"
                         data-string="eBay Connector"
                         string="eBay Connector"
                         data-key="ebay_connector">

                        <!-- ============================================
                             Section 1 — Instance Selection
                        ============================================= -->
                        <h2>eBay Connector</h2>
                        <div class="row mt16 o_settings_container" id="ebay_instance_section">

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Primary eBay Instance</span>
                                    <div class="text-muted">
                                        Select the eBay account to configure.
                                        Manage all instances under
                                        <strong>eBay ▸ Configuration ▸ Instances</strong>.
                                    </div>
                                    <div class="content-group">
                                        <div class="row mt8">
                                            <field name="ebay_instance_id"
                                                   options="{'no_create': True}"
                                                   class="col-lg-9"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box"
                                 attrs="{'invisible': [('ebay_instance_id', '=', False)]}">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Connection Status</span>
                                    <div class="content-group mt8">
                                        <field name="ebay_connection_status"
                                               readonly="1"
                                               widget="badge"
                                               decoration-success="ebay_connection_status == 'connected'"
                                               decoration-danger="ebay_connection_status == 'error'"
                                               decoration-muted="ebay_connection_status == 'not_connected'"/>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- ============================================
                             Section 2 — API Credentials
                        ============================================= -->
                        <h3 attrs="{'invisible': [('ebay_instance_id', '=', False)]}">
                            API Credentials
                        </h3>
                        <div class="row mt16 o_settings_container"
                             id="ebay_credentials_section"
                             attrs="{'invisible': [('ebay_instance_id', '=', False)]}">

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Environment</span>
                                    <div class="text-muted">
                                        Use <em>Sandbox</em> for testing and
                                        <em>Production</em> for live sales.
                                    </div>
                                    <div class="content-group">
                                        <div class="row mt8">
                                            <field name="ebay_environment" class="col-lg-7"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">App ID (Client ID)</span>
                                    <div class="text-muted">
                                        Found in your eBay Developer account under
                                        Application Keys.
                                    </div>
                                    <div class="content-group">
                                        <div class="row mt8">
                                            <field name="ebay_app_id"
                                                   placeholder="YOURNAME-XXXX-XXXX-XXXX"
                                                   class="col-lg-9"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Dev ID</span>
                                    <div class="text-muted">
                                        Your eBay Developer Program Developer ID.
                                    </div>
                                    <div class="content-group">
                                        <div class="row mt8">
                                            <field name="ebay_dev_id"
                                                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                                   class="col-lg-9"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Cert ID (Client Secret)</span>
                                    <div class="text-muted">
                                        Your eBay OAuth 2.0 Client Secret.
                                    </div>
                                    <div class="content-group">
                                        <div class="row mt8">
                                            <field name="ebay_cert_id"
                                                   password="True"
                                                   placeholder="••••••••••••"
                                                   class="col-lg-9"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- ============================================
                             Section 3 — Synchronisation Options
                        ============================================= -->
                        <h3>Synchronisation</h3>
                        <div class="row mt16 o_settings_container" id="ebay_sync_section">

                            <!-- Instant Sync (Webhooks) -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="ebay_instant_sync"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="ebay_instant_sync" class="o_form_label"/>
                                    <div class="text-muted">
                                        Receive eBay event notifications (order updates,
                                        policy changes) in real time via webhooks.
                                        Requires a publicly reachable Odoo URL.
                                    </div>
                                </div>
                            </div>

                            <!-- Batch Sync (Cron) -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="ebay_batch_sync"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="ebay_batch_sync" class="o_form_label"/>
                                    <div class="text-muted">
                                        Periodically fetch new eBay orders and push
                                        inventory updates via Odoo's built-in scheduler.
                                        Saving activates or deactivates the cron jobs.
                                    </div>
                                    <!-- Interval sub-fields, shown only when batch sync is on -->
                                    <div class="content-group"
                                         attrs="{'invisible': [('ebay_batch_sync', '=', False)]}">
                                        <div class="row mt8 align-items-center">
                                            <label string="Sync Every"
                                                   for="ebay_cron_interval_number"
                                                   class="col-lg-4 o_light_label"/>
                                            <field name="ebay_cron_interval_number"
                                                   class="col-lg-2"/>
                                            <field name="ebay_cron_interval_type"
                                                   class="col-lg-4"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
